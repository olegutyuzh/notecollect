  "obverse": {
    "description": "Bohdan Khmelnytskyi (1595-1657) is a great hetman of Ukraine, a public figure and a military leader who established the Ukrainian State by uniting the left-bank and right-bank territories of Ukraine.",
    "lettering": "НАЦІОНАЛЬНИЙ БАНК УКРАЇНИ\r\nГОЛОВА\r\n5\r\nБогдан Хмельницький Гетьман\r\nБОГДАН ХМЕЛЬНИЦЬКИЙ\r\n5\r\n5\r\nП'ЯТЬ ГРИВЕНЬ",
    "lettering_scripts": [
      {
        "name": "Cyrillic"
      }
    ],
    "lettering_translation": "NATIONAL BANK OF UKRAINE\r\nHEAD\r\n5\r\nBohdan Khmelnytskyi Hetman\r\nBOHDAN KHMELNYTSKYI\r\n5\r\n5\r\nFIVE HRYVNIAS",
    "picture": "https://en.numista.com/catalogue/photos/ukraine/626e4fc6c54795.28526166-original.jpg",
    "thumbnail": "https://en.numista.com/catalogue/photos/ukraine/626e4fc6c54795.28526166-180.jpg",
    "picture_copyright": "hex7ech",
    "picture_license_name": "CC BY-NC",
    "picture_license_url": "https://creativecommons.org/licenses/by-nc/4.0/deed.en"
  },
  "reverse": {
    "description": "Illyinska (St. Elias) Church in Subotiv village was built in 1653 as a Khmelnytskyi family burial-vault. B. Khmelnytskyi and his son Tymosh are buried there.",
    "lettering": "П'ЯТЬ ГРИВЕНЬ\r\nНАЦІОНАЛЬНИЙ БАНК УКРАЇНИ\r\n5\r\nЦЕРКВА В СЕЛІ СУБОТОВІ\r\n2005\r\n5",
    "lettering_scripts": [
      {
        "name": "Cyrillic"
      }
    ],
    "lettering_translation": "FIVE HRYVNIAS\r\nNATIONAL BANK OF UKRAINE\r\n5\r\nTHE CHURCH IN THE SUBOTIV VILLAGE\r\n2005\r\n5",
    "picture": "https://en.numista.com/catalogue/photos/ukraine/626e4fc8282c57.61417372-original.jpg",
    "thumbnail": "https://en.numista.com/catalogue/photos/ukraine/626e4fc8282c57.61417372-180.jpg",

  "obverse": {
    "lettering": "១០០០\r\nធនាគារជាគ ចិន កម្ពុជា\r\nទេសាភិបាល\r\nអគ្គបេឡា\r\nមួយពាន់ល\r\n\r\nអ្នកក្លែងក្រដាសប្រាក់នឹងត្រូវផ្តន្ទាទោសតាមច្បាប់ \r\nមួយពាន់ល\r\n1000",
    "lettering_scripts": [
      {
        "name": "Khmer"
      }
    ],
    "lettering_translation": "1000\r\nNational Bank of Cambodia \r\nGovernor\r\nGeneral Treasury\r\nCounterfeiters will be punished according to the law\r\n One thousand\r\n\r\n\r\n\r\nGeneral Tresury\r\nCounterfeiters will be punished according to the law",
